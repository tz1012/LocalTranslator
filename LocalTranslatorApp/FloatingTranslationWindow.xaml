<Window x:Class="LocalTranslatorApp.FloatingTranslationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Translation"
        Width="520"
        Height="340"
        MinWidth="420"
        MinHeight="260"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        Icon="Assets/AppIcon.ico"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1F7AE0" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#E8F2FF" />
        <SolidColorBrush x:Key="TextBrush" Color="#172033" />
        <SolidColorBrush x:Key="MutedBrush" Color="#627083" />
        <SolidColorBrush x:Key="LineBrush" Color="#D7DEE8" />

        <Style TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
    </Window.Resources>

    <Border Margin="10"
            Background="#FFFFFF"
            BorderBrush="#D7DEE8"
            BorderThickness="1"
            CornerRadius="8"
            MouseLeftButtonDown="WindowChrome_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.18" Color="#162033" />
        </Border.Effect>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Border Height="34"
                            Padding="10,0"
                            CornerRadius="6"
                            Background="{StaticResource PrimarySoftBrush}"
                            BorderBrush="{StaticResource PrimaryBrush}"
                            BorderThickness="1">
                        <TextBlock Text="번역"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" />
                    </Border>
                    <TextBlock x:Name="FloatingStatusText"
                               Text="대기 중"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}" />
                </StackPanel>

                <Button Content="×"
                        DockPanel.Dock="Right"
                        Width="34"
                        Padding="0"
                        FontSize="18"
                        Click="Close_Click" />
            </DockPanel>

            <Button x:Name="TargetLanguageButton"
                    Grid.Row="1"
                    MinWidth="160"
                    Height="38"
                    Margin="0,14,0,10"
                    HorizontalAlignment="Left"
                    HorizontalContentAlignment="Left"
                    Click="TargetLanguage_Click" />

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="SourcePreviewRow" Height="110" MinHeight="54" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="*" MinHeight="120" />
                </Grid.RowDefinitions>

                <Border Padding="10"
                        Background="#F8FAFC"
                        BorderBrush="#D7DEE8"
                        BorderThickness="1"
                        CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBlock x:Name="SourcePreviewText"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   Foreground="{StaticResource MutedBrush}" />
                    </ScrollViewer>
                </Border>

                <GridSplitter Grid.Row="1"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="Transparent"
                              ShowsPreview="True"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext" />

                <TextBox x:Name="ResultTextBox"
                         Grid.Row="2"
                         Margin="0,6,0,0"
                         Padding="10"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="15"
                         BorderBrush="{StaticResource LineBrush}"
                         BorderThickness="1"
                         Foreground="{StaticResource TextBrush}" />
            </Grid>

            <DockPanel Grid.Row="3" Margin="0,12,0,0">
                <Button Content="앱에서 열기"
                        DockPanel.Dock="Left"
                        MinWidth="96"
                        Click="OpenMain_Click" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="복사" MinWidth="74" Click="Copy_Click" />
                    <Button Content="삽입  Ctrl+Enter"
                            Margin="8,0,0,0"
                            MinWidth="132"
                            Style="{StaticResource PrimaryButton}"
                            Click="Insert_Click" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
