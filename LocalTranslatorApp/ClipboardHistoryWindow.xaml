<Window x:Class="LocalTranslatorApp.ClipboardHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="클립보드 열기"
        Width="620"
        Height="520"
        MinWidth="520"
        MinHeight="420"
        Icon="Assets/AppIcon.ico"
        Background="#F5F7FA"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1F7AE0" />
        <SolidColorBrush x:Key="TextBrush" Color="#172033" />
        <SolidColorBrush x:Key="MutedBrush" Color="#627083" />
        <SolidColorBrush x:Key="LineBrush" Color="#D7DEE8" />

        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="클립보드 열기"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="앱이 실행 중일 때 감지한 최근 클립보드 텍스트 중 하나를 선택합니다."
                       Margin="0,8,0,18"
                       Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <ListBox x:Name="ClipboardList"
                 Grid.Row="1"
                 BorderBrush="{StaticResource LineBrush}"
                 MouseDoubleClick="ClipboardList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12" BorderBrush="#E7ECF2" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="{Binding Preview}"
                                       TextWrapping="Wrap"
                                       FontSize="14"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock Text="{Binding LengthText}"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="취소"
                    Width="82"
                    Click="Cancel_Click" />
            <Button Content="선택"
                    Width="82"
                    Margin="10,0,0,0"
                    Style="{StaticResource PrimaryButton}"
                    Click="Select_Click" />
        </StackPanel>
    </Grid>
</Window>
