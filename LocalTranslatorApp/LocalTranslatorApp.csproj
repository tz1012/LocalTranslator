<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <AssemblyName>LocalTranslator</AssemblyName>
    <RootNamespace>LocalTranslatorApp</RootNamespace>
    <Version>0.6.1</Version>
    <FileVersion>0.6.1.0</FileVersion>
    <AssemblyVersion>0.6.1.0</AssemblyVersion>
    <Product>Local Translator</Product>
    <Description>Local LLM translator for Windows using LM Studio.</Description>
    <ApplicationIcon>Assets\AppIcon.ico</ApplicationIcon>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\AppIcon.ico" />
    <Resource Include="Assets\AppIcon.ico" />
  </ItemGroup>

</Project>
