<Window x:Class="LocalTranslatorApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="860"
        Height="680"
        MinWidth="760"
        MinHeight="560"
        Icon="Assets/AppIcon.ico"
        Background="#F5F7FA"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1F7AE0" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#E8F2FF" />
        <SolidColorBrush x:Key="TextBrush" Color="#172033" />
        <SolidColorBrush x:Key="MutedBrush" Color="#627083" />
        <SolidColorBrush x:Key="LineBrush" Color="#D7DEE8" />

        <Style TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E7ECF2" BorderThickness="0,0,1,0">
            <StackPanel Margin="28,34">
                <TextBlock Text="설정" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,22" />
                <Button x:Name="GeneralNav" Content="일반" HorizontalContentAlignment="Left" Click="GeneralNav_Click" />
                <Button x:Name="ShortcutNav" Content="키보드 단축키" HorizontalContentAlignment="Left" Margin="0,10,0,0" Click="ShortcutNav_Click" />
                <Button x:Name="LanguageNav" Content="언어와 테마" HorizontalContentAlignment="Left" Margin="0,10,0,0" Click="LanguageNav_Click" />
                <Button x:Name="LmStudioNav" Content="LM Studio" HorizontalContentAlignment="Left" Margin="0,10,0,0" Click="LmStudioNav_Click" />
                <Button x:Name="UpdateNav" Content="업데이트" HorizontalContentAlignment="Left" Margin="0,10,0,0" Click="UpdateNav_Click" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="36,34,46,34">
                <StackPanel x:Name="GeneralPanel">
                    <TextBlock Text="일반" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="앱 실행, 플로팅 아이콘, 닫기 동작을 설정합니다." Margin="0,8,0,26" Foreground="{StaticResource MutedBrush}" />
                    <CheckBox x:Name="LaunchAtStartupCheck" Content="기기를 켜면 앱이 자동으로 열립니다" FontSize="15" Margin="0,0,0,18" />
                    <CheckBox x:Name="FloatingIconCheck" Content="플로팅 아이콘 활성화" FontSize="15" Margin="0,0,0,28" />

                    <TextBlock Text="빠른 액세스 옵션" FontSize="17" FontWeight="Bold" Margin="0,0,0,12" />
                    <RadioButton x:Name="QuickFloatingRadio" Content="작은 플로팅 창에 표시" Margin="0,0,0,10" />
                    <RadioButton x:Name="QuickMainRadio" Content="앱에 표시" Margin="0,0,0,26" />

                    <TextBlock Text="앱 닫기" FontSize="17" FontWeight="Bold" Margin="0,0,0,12" />
                    <RadioButton x:Name="CloseBackgroundRadio" Content="단축키로 활성화할 수 있도록 백그라운드에 유지" Margin="0,0,0,10" />
                    <RadioButton x:Name="CloseExitRadio" Content="앱을 종료" Margin="0,0,0,10" />
                    <RadioButton x:Name="CloseAskRadio" Content="매번 묻기" />
                </StackPanel>

                <StackPanel x:Name="ShortcutPanel" Visibility="Collapsed">
                    <TextBlock Text="단축키 설정" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="입력칸을 클릭한 뒤 원하는 단축키를 누르세요. 번역 단축키는 같은 조합을 두 번 누르면 DeepL식 반복 단축키로 저장됩니다."
                               Margin="0,8,0,26"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedBrush}" />

                    <TextBlock Text="선택한 텍스트 번역" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox x:Name="TranslateShortcutText"
                             Width="220"
                             HorizontalAlignment="Left"
                             IsReadOnly="True"
                             Cursor="Hand"
                             GotKeyboardFocus="ShortcutText_GotKeyboardFocus"
                             PreviewKeyDown="TranslateShortcutText_PreviewKeyDown" />
                    <TextBlock Text="예: Ctrl+C를 두 번 누르면 Ctrl+C,C로 저장됩니다."
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,8,0,24" />

                    <TextBlock Text="번역문 바로 삽입" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox x:Name="InsertShortcutText"
                             Width="220"
                             HorizontalAlignment="Left"
                             IsReadOnly="True"
                             Cursor="Hand"
                             GotKeyboardFocus="ShortcutText_GotKeyboardFocus"
                             PreviewKeyDown="InsertShortcutText_PreviewKeyDown" />

                    <TextBlock Text="더블 입력 간격(ms)" FontWeight="SemiBold" Margin="0,24,0,8" />
                    <TextBox x:Name="DoubleCopyIntervalText" Width="120" HorizontalAlignment="Left" />
                </StackPanel>

                <StackPanel x:Name="LanguagePanel" Visibility="Collapsed">
                    <TextBlock Text="언어와 테마" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="기본 번역 언어와 앱 테마를 설정합니다." Margin="0,8,0,26" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="원문 언어" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Button x:Name="SourceLanguageButton"
                            Width="260"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Left"
                            Margin="0,0,0,18"
                            Click="SourceLanguage_Click" />
                    <TextBlock Text="번역 언어" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Button x:Name="TargetLanguageButton"
                            Width="260"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Left"
                            Margin="0,0,0,28"
                            Click="TargetLanguage_Click" />
                    <TextBlock Text="테마" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ComboBox x:Name="ThemeCombo" Width="220" HorizontalAlignment="Left">
                        <ComboBoxItem Content="System" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </StackPanel>

                <StackPanel x:Name="LmStudioPanel" Visibility="Collapsed">
                    <TextBlock Text="LM Studio" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="LM Studio에서 모델을 로드하면 OpenAI 호환 API로 자동 사용합니다." Margin="0,8,0,26" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="서버 주소" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox x:Name="EndpointText" />
                    <TextBlock Text="모델 이름" FontWeight="SemiBold" Margin="0,18,0,8" />
                    <TextBox x:Name="ModelText" />
                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                        <StackPanel Width="160">
                            <TextBlock Text="Temperature" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBox x:Name="TemperatureText" />
                        </StackPanel>
                        <StackPanel Width="160" Margin="18,0,0,0">
                            <TextBlock Text="Max tokens" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBox x:Name="MaxTokensText" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="번역 지침" FontWeight="SemiBold" Margin="0,22,0,8" />
                    <TextBox x:Name="InstructionText"
                             Height="120"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top" />
                </StackPanel>

                <StackPanel x:Name="UpdatePanel" Visibility="Collapsed">
                    <TextBlock Text="업데이트" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="GitHub Releases에 새 버전이 올라오면 앱에서 알려주고 설치 파일을 받아 실행합니다."
                               Margin="0,8,0,26"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedBrush}" />
                    <CheckBox x:Name="CheckForUpdatesCheck"
                              Content="앱 시작 시와 실행 중에 새 버전 확인"
                              FontSize="15"
                              Margin="0,0,0,22" />
                    <TextBlock Text="GitHub 저장소" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox x:Name="UpdateRepositoryText"
                             Width="360"
                             HorizontalAlignment="Left" />
                    <TextBlock Text="예: tz1012/LocalTranslator"
                               FontSize="12"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,8,0,18" />
                    <TextBlock Text="설치 파일 이름 포함 문자열" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBox x:Name="UpdateAssetPatternText"
                             Width="220"
                             HorizontalAlignment="Left" />
                    <TextBlock Text="릴리스 첨부 파일 중 이 문자열이 포함된 파일을 업데이트 설치 파일로 사용합니다."
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,8,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,34,0,0">
                    <Button Content="취소" Width="86" Click="Cancel_Click" />
                    <Button Content="저장" Width="86" Margin="10,0,0,0" Style="{StaticResource PrimaryButton}" Click="Save_Click" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
